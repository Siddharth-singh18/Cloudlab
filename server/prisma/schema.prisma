// CloudLab — Prisma schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  color        String   @default("#58a6ff")
  githubId     String?  @unique
  githubToken  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedProjects     Project[]         @relation("owner")
  collaborations    Collaborator[]
  comments          Comment[]
  commentReplies    CommentReply[]
  suggestions       Suggestion[]
  chatMessages      ChatMessage[]
  reviewSessions    ReviewSession[]   @relation("reviewAuthor")
  activityEvents    ActivityEvent[]
  refreshTokens     RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  language    String   @default("TypeScript")
  isPublic    Boolean  @default(false)
  ownerId     String
  owner       User     @relation("owner", fields: [ownerId], references: [id])
  storagePath String   // filesystem path: /projects/{userId}/{projectId}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collaborators  Collaborator[]
  reviewSessions ReviewSession[]
  chatMessages   ChatMessage[]
  activityEvents ActivityEvent[]
  branches       Branch[]

  @@index([ownerId])
}

model Collaborator {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      CollabRole @default(VIEWER)
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

enum CollabRole {
  OWNER
  EDITOR
  REVIEWER
  VIEWER
}

// ─── Git / Branches ───────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  reviewSessions ReviewSession[]

  @@unique([projectId, name])
}

// ─── Review Sessions ──────────────────────────────────────────────────────────

model ReviewSession {
  id          String        @id @default(cuid())
  title       String
  description String?
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?       @relation(fields: [branchId], references: [id])
  branchName  String        // stored separately for flexibility
  authorId    String
  author      User          @relation("reviewAuthor", fields: [authorId], references: [id])
  status      ReviewStatus  @default(OPEN)
  previewUrl  String?
  buildStatus BuildStatus   @default(IDLE)
  storagePath String?       // isolated workspace path
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  comments    Comment[]
  suggestions Suggestion[]
  chatMessages ChatMessage[]
  activityEvents ActivityEvent[]

  @@index([projectId])
}

enum ReviewStatus {
  OPEN
  MERGED
  CLOSED
}

enum BuildStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id        String        @id @default(cuid())
  reviewId  String
  review    ReviewSession @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  filePath  String
  lineStart Int
  lineEnd   Int
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  body      String        @db.Text
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  replies CommentReply[]

  @@index([reviewId])
}

model CommentReply {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())
}

// ─── Suggestions ──────────────────────────────────────────────────────────────

model Suggestion {
  id            String           @id @default(cuid())
  reviewId      String
  review        ReviewSession    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  filePath      String
  lineStart     Int
  lineEnd       Int
  originalCode  String           @db.Text
  suggestedCode String           @db.Text
  authorId      String
  author        User             @relation(fields: [authorId], references: [id])
  status        SuggestionStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([reviewId])
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String         @id @default(cuid())
  body      String         @db.Text
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id])
  reviewId  String?
  review    ReviewSession? @relation(fields: [reviewId], references: [id])
  createdAt DateTime       @default(now())

  @@index([projectId])
  @@index([reviewId])
}

// ─── Activity ─────────────────────────────────────────────────────────────────

model ActivityEvent {
  id          String        @id @default(cuid())
  type        ActivityType
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  reviewId    String?
  review      ReviewSession? @relation(fields: [reviewId], references: [id])
  description String
  filePath    String?
  line        Int?
  createdAt   DateTime      @default(now())

  @@index([projectId])
  @@index([reviewId])
}

enum ActivityType {
  EDIT
  COMMENT
  SUGGESTION
  BUILD_PASS
  BUILD_FAIL
  PREVIEW_DEPLOY
  MERGE
  APPROVE
  JOIN
  LEAVE
}
